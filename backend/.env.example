# Copy this file to `.env` and fill in real values.
# Nothing in this file is a real secret — safe to commit `.env.example`, never commit `.env`.

# --- App ---
PROJECT_NAME="Physiotherapy AI Receptionist"
ENV=development
DEBUG=true

# --- Database ---
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/physio_receptionist

# --- Auth (Security phase) ---
JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# --- AI / RAG (Core AI Agent + RAG phases) ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=./chroma_data

# --- Google Calendar (Appointment Management phase) ---
GOOGLE_CALENDAR_CREDENTIALS_JSON=
GOOGLE_CALENDAR_ID=

# --- Twilio / WhatsApp (WhatsApp phase) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- Voice (Voice Receptionist phase) ---
VAPI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Email notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=

# --- Clinic defaults ---
CLINIC_NAME="Physiotherapy Clinic"
CLINIC_TIMEZONE=Asia/Kolkata
